# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-aoai-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Reasoning effort: minimal | low | medium | high
OPENAI_REASONING_EFFORT=low

# Skip TLS verification for corporate networks with inspection. Use false in production.
INSECURE_TLS=false

# AI Gateway (Azure API Management) — optional. If true, use the gateway URL/key below.
USE_APIM_GATEWAY=false
APIM_GATEWAY_URL=
APIM_SUBSCRIPTION_KEY=
AGENT_ID=sales-cockpit-agent

# Brand shown in agent responses. Requires backend restart after changes.
BRAND_NAME=Acme

# CORS — frontend origin
FRONTEND_URL=http://localhost:5173

# Backend port
PORT=8000
